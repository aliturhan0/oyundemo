  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: " S\u0131n\u0131rl\u0131 Cephane: Oyunda s\u0131n\u0131rs\u0131z mermi
    yoktur! Haritada rastgele veya belirli s\xFCrelerle spawn olan Cephane Kutular\u0131n\u0131
    toplayarak yedek mermini doldur.\n\r\nLevel 1 : Hayatta kalmak i\xE7in toplam
    15 zombi temizlemelisin.\r\n\nLevel 2 : Dikkat et! Orman\u0131n karanl\u0131\u011F\u0131nda;
    daha dayan\u0131kl\u0131, daha h\u0131zl\u0131 ve daha tehlikeli olan Mutant
    Zombiler pusu kurmu\u015F durumda.\r B\xF6l\xFCm\xFC ge\xE7mek i\xE7in 10 tane
    mutantu temizlemelisin.\n\nTaktik: Zombiler yakla\u015Ft\u0131k\xE7a gerilim
    m\xFCzi\u011Fi h\u0131zlan\u0131r. Kulakl\u0131\u011F\u0131n\u0131 tak ve m\xFCzi\u011Fin
    sesini iyi dinle!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 1f8fe66c91dde3841ac99e72925eeb29, type: 2}
  m_sharedMaterial: {fileID: -4383862590563831049, guid: 1f8fe66c91dde3841ac99e72925eeb29,
